{
  "name": "puuiy-lang",
  "displayName": "Puuiy Language Support",
  "description": "Syntax highlighting and language support for Puuiy (.piy) scripting language",
  "version": "1.0.0",
  "publisher": "PuuiyGame",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:piy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piy.run",
        "title": "Puuiy: Run Current File"
      },
      {
        "command": "piy.format",
        "title": "Puuiy: Format Document"
      },
      {
        "command": "piy.fixIndent",
        "title": "Puuiy: Fix Indentation"
      }
    ],
    "languages": [
      {
        "id": "piy",
        "aliases": [
          "Puuiy",
          "piy"
        ],
        "extensions": [
          ".piy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "piy",
        "scopeName": "source.piy",
        "path": "./syntaxes/piy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "piy",
        "label": "Puuiy Snippets",
        "path": "./snippets/piy.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "typescript": "^4.9.5"
  }
}
